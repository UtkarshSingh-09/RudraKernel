# SIEGE Environment Variables
# Copy this file to .env and fill in values.

# Hugging Face token for deployment (Step 26)
HF_TOKEN=

# Weights & Biases API key for training logging (Step 23/25)
WANDB_API_KEY=
WANDB_PROJECT=siege-env
WANDB_ENTITY=

# OpenEnv configuration
OPENENV_PORT=8000
OPENENV_HOST=0.0.0.0

# Training configuration
GRPO_MODEL_NAME=Qwen/Qwen2.5-3B-Instruct
GRPO_EPISODES=500
GRPO_SEED=42
